msgid "$\\\\{0\\\\to a,2\\\\to b\\\\}^{-1}=\\\\{a\\\\to0,b\\\\to2\\\\}$"
msgstr "$\\\\{0\\\\to a,2\\\\to b\\\\}^{-1}=\\\\{a\\\\to0,b\\\\to2\\\\}$"

