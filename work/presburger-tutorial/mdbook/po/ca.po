"$R=\\\\{0\\\\to a\\\\}$、$Q=\\\\{a\\\\to10\\\\}$ 得 $Q\\\\circ R=\\\\{0\\"
"\\to10\\\\}$"
msgstr ""
"$R=\\\\{0\\\\to a\\\\}$, $Q=\\\\{a\\\\to10\\\\}$ obté $Q\\\\circ R=\\\\{0\\"
"\\to10\\\\}$"

#: src/appendices.md:1438
msgid "Image $R\\[A\\]$"
msgstr "Image $R\\[A\\]$"

#: src/appendices.md:1438
msgid "$\\\\operatorname{Rel}(X,Y)\\\\times2^X\\\\to2^Y$"
msgstr "$\\\\operatorname{Rel}(X,Y)\\\\times2^X\\\\to2^Y$"

#: src/appendices.md:1438
msgid "$R\\[A\\]=\\\\{y\\\\mid\\\\exists x\\\\in A:R(x,y)\\\\}$"
msgstr "$R\\[A\\]=\\\\{y\\\\mid\\\\exists x\\\\in A:R(x,y)\\\\}$"

