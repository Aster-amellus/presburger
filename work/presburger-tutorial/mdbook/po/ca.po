msgid ""
"$\\\\operatorname{Rel}(Y,Z)\\\\times\\\\operatorname{Rel}(X,Y)\\\\to\\"
"\\operatorname{Rel}(X,Z)$"
msgstr ""
"$\\\\operatorname{Rel}(Y,Z)\\\\times\\\\operatorname{Rel}(X,Y)\\\\to\\"
"\\operatorname{Rel}(X,Z)$"

#: src/appendices.md:1437
msgid "$(Q\\\\circ R)(x,z)\\\\iff\\\\exists y:R(x,y)\\\\land Q(y,z)$"
msgstr "$(Q\\\\circ R)(x,z)\\\\iff\\\\exists y:R(x,y)\\\\land Q(y,z)$"

#: src/appendices.md:1437
msgid "先走 $R$，再走 $Q$"
msgstr "Ves primer $R$ i després $Q$"

